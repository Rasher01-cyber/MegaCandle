PORT=4000

# Google OAuth — Web Client ID (Google Cloud Console → Credentials).
# Used to verify tokens and is published to the SPA via GET /api/auth/public-config (safe to expose).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret for session cookies
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=2592000

# SQLite database
DATABASE_URL="file:./dev.db"

FRONTEND_ORIGIN="http://localhost:5173"

# File uploads
UPLOAD_DIR="./uploads"

# MetaAPI — WEBSITE-ONLY TRADING (no MT5 terminal). Sign up: https://metaapi.cloud → copy token
METAAPI_TOKEN=

# Local MT5 bridge for live trading (optional). Set to 0 when using METAAPI_TOKEN only
LOCAL_MT5_ENABLED=0

# Always pull MT5 history into Records when terminal is open (recommended: 1)
LOCAL_MT5_HISTORY_SYNC=1

