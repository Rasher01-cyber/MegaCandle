generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TradeSide {
  LONG
  SHORT
}

enum MtPlatform {
  MT4
  MT5
}

enum MtCommandType {
  OPEN
  CLOSE
}

enum MtCommandStatus {
  PENDING
  DISPATCHED
  EXECUTED
  FAILED
}

model User {
  id           String    @id @default(cuid())
  googleId     String?   @unique
  email        String    @unique
  name         String
  picture      String?
  passwordHash String?
  createdAt    DateTime  @default(now())
  sessions     Session[]
  trades       Trade[]
  tags         Tag[]
  mtAccounts   MtAccount[]
}

model Session {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceLabel       String?
  deviceFingerprint String
  ipAddress         String?
  userAgent         String?
  lastActiveAt      DateTime @default(now())
  expiresAt         DateTime
  revoked           Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model Trade {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol         String
  side           TradeSide
  entryPrice     Float
  exitPrice      Float
  lotSize        Float
  openTime       DateTime
  closeTime      DateTime
  pnl            Float
  fees           Float      @default(0)
  rating         Int?
  strategy       String?
  notes          String?
  screenshotPath String?
  createdAt      DateTime   @default(now())
  tradeTags      TradeTag[]
}

model Tag {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String
  tradeTags TradeTag[]
  @@unique([userId, name])
}

model TradeTag {
  tradeId String
  tagId   String
  trade   Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([tradeId, tagId])
}

model MtAccount {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  label            String       @default("MT5 Account")
  platform         MtPlatform   @default(MT5)
  apiTokenHash     String?
  pairingCode      String       @unique
  pairingExpiresAt DateTime
  brokerName       String?
  brokerServer     String?
  accountLogin     String?
  brokerPasswordEnc String?
  metaApiAccountId  String?
  balance          Float?
  equity           Float?
  connected        Boolean      @default(false)
  lastSeenAt       DateTime?
  revoked          Boolean      @default(false)
  isHosted         Boolean      @default(false)
  isDefault        Boolean      @default(false)
  createdAt        DateTime     @default(now())
  positions        MtPosition[]
  commands         MtCommand[]
}

model MtPosition {
  id           String    @id @default(cuid())
  accountId    String
  account      MtAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ticket       BigInt
  symbol       String
  side         TradeSide
  volume       Float
  openPrice    Float
  currentPrice Float
  profit       Float     @default(0)
  openTime     DateTime
  updatedAt    DateTime  @updatedAt

  @@unique([accountId, ticket])
}

model MtCommand {
  id         String          @id @default(cuid())
  accountId  String
  account    MtAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       MtCommandType
  status     MtCommandStatus @default(PENDING)
  symbol     String?
  side       TradeSide?
  volume     Float?
  ticket     BigInt?
  sl         Float?
  tp         Float?
  errorMsg   String?
  executedAt DateTime?
  createdAt  DateTime        @default(now())
}

