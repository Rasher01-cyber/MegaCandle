PORT=4000

# Google OAuth — Web Client ID (Google Cloud Console → Credentials).
# Used to verify tokens and is published to the SPA via GET /api/auth/public-config (safe to expose).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret for session cookies
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=2592000

# SQLite database
DATABASE_URL="file:./dev.db"

FRONTEND_ORIGIN="http://localhost:5173"

# File uploads
UPLOAD_DIR="./uploads"

# MetaAPI — direct MT5/MT4 login (no local EA). Free tier: https://metaapi.cloud
METAAPI_TOKEN=

# Local MT5 bridge (Windows) — syncs with MetaTrader 5 running on this PC via Python
LOCAL_MT5_ENABLED=1

